VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# ---------------------------------------------------------------------------
# Google Integration (optional — leave blank to disable)
# ---------------------------------------------------------------------------
# Obtain a service account JSON key from the Google Cloud Console.
# See GOOGLE_INTEGRATION_SETUP.md for full step-by-step instructions.

# Service account client_email from the downloaded JSON key file.
VITE_GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com

# The private_key value from the JSON key file.
# Replace every literal newline in the PEM with the two-character sequence \n
# so the entire value fits on one line (most CI/hosting providers require this).
VITE_GOOGLE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n

# Google Drive folder ID where patient file subfolders will be created.
# Create a folder in Google Drive, share it with the service account (Editor),
# then copy the folder ID from its URL:
#   https://drive.google.com/drive/folders/<FOLDER_ID>
VITE_GOOGLE_DRIVE_FOLDER_ID=your_drive_root_folder_id

# Google Spreadsheet ID of the sheet used for appointments/patient backup.
# Share the spreadsheet with the service account (Editor), then copy the ID
# from its URL:
#   https://docs.google.com/spreadsheets/d/<SPREADSHEET_ID>/edit
VITE_GOOGLE_SPREADSHEET_ID=your_spreadsheet_id

# SECURITY WARNING:
# Any variable prefixed with VITE_ is embedded in the client-side bundle and
# is visible to anyone who downloads your site assets.  For production use,
# consider moving these calls behind a Cloudflare Worker or Netlify Function
# that keeps the private key server-side.  For a personal / single-clinic
# deployment where you control access to the site, VITE_ variables are
# acceptable.
